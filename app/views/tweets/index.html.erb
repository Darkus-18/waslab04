<body>
  <% content_for :title, "Waslab04" %>

  <div class=container>
    <header class="header-section">
      <h1 class="wottitle">Wall of Tweets · RoR Edition</h1>
      <p class="subtitle">A minimal wall for quick thoughts. Clean and focused.</p>
    </header>

    <% if notice %>
      <div class="flash flash--notice">
        <span class="ok"><%= notice %></span> </div>
    <% end %>

    <% if alert %>
      <div class="flash flash--alert">
        <span class="err"><%= alert %></span>
      </div>
    <% end %>

    <div class=walltweet>
      <form action="/tweets" accept-charset="UTF-8" method="post"><input type="hidden" name="authenticity_token" value=<%= form_authenticity_token %> autocomplete="off">
        <div class="form-grid">
          <div class="form-row">
            <label for="tweet_author">Your name:</label>
            <input placeholder="Serious Contributor" type="text" name="tweet[author]" id="tweet_author">
          </div>
          <div class="form-row">
            <label for="tweet_content">Your tweet:</label>
            <textarea placeholder="Share something concise and useful…" name="tweet[content]" id="tweet_content"></textarea>
          </div>
          <div class="actions">
            <input type="submit" name="commit" value="Tweet!" data-disable-with="Tweet!">
          </div>
        </div>
      </form>
    </div>

<div id="tweets">
  <% current_date = nil %>
  <% @tweets.each do |tweet| %>
    <% if tweet.created_at.to_date != current_date %>
      <div class="date-separator">
        <%= tweet.created_at.strftime("%A, %B %d, %Y").upcase %>
      </div>
      <% current_date = tweet.created_at.to_date %>
    <% end %>

    <div class="tweet-card">
      <div class="tweet-sidebar">
        <div class="likes-container">
          <span class="numlikes"><%= tweet.likes_count rescue 0 %></span>
          <span class="smallfont">likes</span>
          <div class="button_to">
            <%= button_to 'like', like_tweet_path(tweet), method: :put %>
          </div>
        </div>
      </div>

        <div class="item">
          <h4>
            <em><%= tweet.author %></em> · <%= tweet.created_at.strftime("%H:%M") %>
          </h4>
          <p><%= tweet.content %></p>
        </div>
    </div>
  <% end %>
</div>



</body>

<style>
  :root {
      --bg: #fbfbfb;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #6b7280;
      --line: #e5e7eb;
      --accent: #4f7cac;
      --accent-ink: #ffffff;
      --success: #16a34a;
      --danger: #dc2626;
      --radius: 14px;
      --shadow: 0 1px 2px rgba(0, 0, 0, .04), 0 6px 20px rgba(0, 0, 0, .04);
  }

  body {
    margin: 0;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Inter, Arial, "Noto Sans", "Helvetica Neue", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  * {
    box-sizing: border-box;
  }

  div {
      display: block;
      unicode-bidi: isolate;
  }

  .wottitle {
    margin: 0 0 18px;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .subtitle {
    margin-top: 4px;
    color: var(--muted);
    font-size: 14px;
  }

  .container {
    max-width: 860px;
    margin: 48px auto 80px;
    padding: 0 20px;
  }

  .walltweet {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px;
    box-shadow: var(--shadow);
    margin: 20px 0 28px;
  }

  form {
    display: block;
    margin-top: 0em;
    unicode-bidi: isolate;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .form-row {
    display: grid;
    gap: 6px;
  }

  label {
    font-size: 13px;
    color: var(--muted);
  }

  label {
    cursor: default;
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 2px;
  }

  button, input[type="submit"] {
    appearance: none;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: var(--accent-ink);
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: transform .02s ease, filter .15s ease, background .15s ease, color .15s ease;
    min-width: 90px;
    text-align: center;
  }

  button:hover, input[type="submit"]:hover {
    filter: brightness(1.02);
  }

  button:active, input[type="submit"]:active {
    transform: translateY(1px);
  }

  textarea {
    resize: vertical;
    min-height: 72px;
  }

  input[type="text"], textarea {
    width: 100%;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    outline: none;
    transition: border-color .15s ease, box-shadow .15s ease;
  }

  input[type="text"]:focus, textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
  }


  /*Tweets*/

  .tweet-card {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 16px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px;
    box-shadow: var(--shadow);
    margin: 12px 0;
  }

  .tweet-sidebar {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .likes-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 8px;
    border: 1px dashed var(--line);
    border-radius: 10px;
  }

  .numlikes {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
  }

  .smallfont {
    font-size: 12px;
    color: var(--muted);;
  }

  .button_to, .button_to button {
    margin: 0;
  }

  .button_to button {
    appearance: none;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: var(--accent-ink);
    font-weight: 600;
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: transform .02s ease, filter .15s ease, background .15s ease, color .15s ease;
    min-width: 90px;
    text-align: center;
  }


  .tweet-body-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .item h4 {
    margin: 0 0 6px;
    font-size: 14px;
    color: var(--muted);
    font-weight: 600;
  }

  .item h4 em {
    font-style: italic;
  }

  .item p {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .date-separator {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0 10px;
    color: var(--muted);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .date-separator::before, .date-separator::after {
    content: "";
    height: 1px;
    flex: 1;
    background: var(--line);
  }

  /*Alertas*/

  .flash--alert {
    border-left-color: var(--danger);
  }

  .flash .err {
    color: var(--danger);
    font-weight: 600;
  }


  .flash .ok {
    color: var(--success);
    font-weight: 600;
  }

  .flash {
    display: flex;
    gap: 12px;
    align-items: center;
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 4px solid var(--success);
    border-radius: var(--radius);
    padding: 12px 14px;
    box-shadow: var(--shadow);
    margin: 18px 0 8px;
    font-size: 14px;
  }



</style>